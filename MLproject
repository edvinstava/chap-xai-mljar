name: chap_xai_template

uv_env: pyproject.toml
provides_native_shap: true

target: disease_cases
required_covariates:
  - rainfall
  - mean_temperature
  - population
allow_free_additional_continuous_covariates: False
supported_period_type: month
user_options: {}

meta_data:
  display_name: XAI model template
  description: >
    Template for a CHAP-compatible external model with native SHAP support.
    Clone or fork this repository and swap out the model in train.py /
    predict.py to build your own explainable disease-forecasting model.
  author: Your Name
  contact_email: your@email.com

adapters:
  Cases: disease_cases
  E: population
  month: month
  ID_year: year
  ID_spat: location
  rainsum: rainfall
  meantemperature: mean_temperature

entry_points:
  train:
    parameters:
      train_data: path
      model: str
    command: "python train.py {train_data} {model}"
  predict:
    parameters:
      historic_data: path
      future_data: path
      model: str
      out_file: path
    command: "python predict.py {model} {historic_data} {future_data} {out_file}"
