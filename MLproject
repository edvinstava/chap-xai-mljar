name: chap_xai_mljar

uv_env: pyproject.toml
provides_native_shap: true

target: disease_cases
required_covariates:
  - rainfall
  - mean_temperature
  - population
allow_free_additional_continuous_covariates: False
supported_period_type: month
user_options: {}

meta_data:
  display_name: CHAP XAI MLJAR
  description: >
    MLJAR AutoML regression with lagged climate and population features,
    log1p target transform, and native SHAP outputs for CHAP.
  author: Edvin
  author_note: MLJAR AutoML with native SHAP
  contact_email: edvin@devotta.no

adapters:
  Cases: disease_cases
  E: population
  month: month
  ID_year: year
  ID_spat: location
  rainsum: rainfall
  meantemperature: mean_temperature

entry_points:
  train:
    parameters:
      train_data: path
      model: str
    command: "python train.py {train_data} {model}"
  predict:
    parameters:
      historic_data: path
      future_data: path
      model: str
      out_file: path
    command: "python predict.py {model} {historic_data} {future_data} {out_file}"
